flowchart LR
    U["👤 User<br/>(browser)"]
    UI["Web App<br/>(single-page UI)"]
    API["KnowledgeHub API<br/>FastAPI backend"]

    PG[("PostgreSQL<br/>documents · versions<br/>permissions · logs")]
